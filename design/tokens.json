{
  "$schema": "https://tr.designtokens.org/format/tokens.schema.json",
  "$description": "Aurora design tokens (W3C DTCG). Glassy SaaS kit — cool slate + blue, Sora display, mono labels, glassmorphism, RTL-ready.",
  "color": {
    "$type": "color",
    "brand": {
      "50": { "$value": "#eff6ff" },
      "100": { "$value": "#dbeafe" },
      "200": { "$value": "#bfdbfe" },
      "300": { "$value": "#93c5fd" },
      "400": { "$value": "#60a5fa" },
      "500": { "$value": "#3b82f6" },
      "600": { "$value": "#2563eb" },
      "700": { "$value": "#1d4ed8" }
    },
    "light": {
      "background": { "$value": "#f5f8fd" },
      "foreground": { "$value": "#0b1324" },
      "card": { "$value": "#ffffff" },
      "muted": { "$value": "#eef2fb" },
      "muted-foreground": { "$value": "#5b6b86" },
      "border": { "$value": "#e2e8f5" },
      "primary": { "$value": "#3b82f6" },
      "accent": { "$value": "#6366f1" },
      "ink": { "$value": "#0b1220" }
    },
    "dark": {
      "background": { "$value": "#060b16" },
      "foreground": { "$value": "#e8eefb" },
      "card": { "$value": "#0e1626" },
      "border": { "$value": "#1d2a44" },
      "primary": { "$value": "#60a5fa" },
      "accent": { "$value": "#818cf8" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Sora", "Cairo", "sans-serif"] },
    "sans": { "$value": ["Inter", "Cairo", "sans-serif"] },
    "mono": { "$value": ["JetBrains Mono", "monospace"] }
  },
  "radius": {
    "$type": "dimension",
    "DEFAULT": { "$value": "1rem" },
    "lg": { "$value": "1.5rem" }
  }
}
